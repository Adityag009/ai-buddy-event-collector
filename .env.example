# Copy to .env and fill in. Do not commit .env.

# Database
SUPABASE_URL=
SUPABASE_KEY=

# LLM (pick one provider via LLM_PROVIDER)
LLM_PROVIDER=ollama
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_OPENAI_API_KEY=ollama
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# App
APP_MODE=
SKIP_INSTAGRAM=
# Pipeline: optional path to org CSV (default config/Nijmegen Student Organizations Database.csv)
ORGS_CSV_PATH=
# website scraper: static | js (Crawl4AI)
WEB_SCRAPER_MODE=static

# Instagram (optional)
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_SESSION_FILE=
INSTAGRAM_SESSION_ONLY=
INSTAGRAM_EXTRA_QUERY_SLEEP=
